spring.application.name=veterinary-clinic-backend

# Frontend developers without PostgreSQL installed do not need to copy this
# file at all: run with the h2 profile instead, which is self-contained.
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=h2
# See src/main/resources/application-h2.properties.

spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/vet_clinic}
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:postgres}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

app.jwt.secret=${JWT_SECRET:change-me-in-local-application-properties}
app.jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

app.seed.admin.email=${SEED_ADMIN_EMAIL:admin@clinic.com}
app.seed.admin.password=${SEED_ADMIN_PASSWORD:change-me}
app.seed.vet1.email=${SEED_VET1_EMAIL:vet1@clinic.com}
app.seed.vet1.password=${SEED_VET1_PASSWORD:change-me}
app.seed.vet2.email=${SEED_VET2_EMAIL:vet2@clinic.com}
app.seed.vet2.password=${SEED_VET2_PASSWORD:change-me}
app.seed.receptionist.email=${SEED_RECEPTIONIST_EMAIL:receptionist@clinic.com}
app.seed.receptionist.password=${SEED_RECEPTIONIST_PASSWORD:change-me}

app.seed.demo-data.enabled=${SEED_DEMO_DATA_ENABLED:true}
